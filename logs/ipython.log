2026-05-14 13:58:43,635 INFO ipython import frappe, json
2026-05-14 13:58:43,635 INFO ipython ws = frappe.get_doc("Workspace", "Farm Management System")
2026-05-14 13:58:43,636 INFO ipython # Collect packaging links (excluding the Card Break for Packaging Module)
2026-05-14 13:58:43,636 INFO ipython pkg_links = [l for l in ws.links if l.type == "Link" and "ackag" in (l.label or "")]
2026-05-14 13:58:43,636 INFO ipython pkg_card_break = next((l for l in ws.links if l.type == "Card Break" and l.label == "Packaging Module"), None)
2026-05-14 13:58:43,636 INFO ipython # Remove the Packaging Module Card Break entirely
2026-05-14 13:58:43,637 INFO ipython if pkg_card_break:
    ws.links.remove(pkg_card_break)
2026-05-14 13:58:43,637 INFO ipython # Find "Other Important Tools" card break and bump its link_count
2026-05-14 13:58:43,637 INFO ipython oit = next(l for l in ws.links if l.type == "Card Break" and l.label == "Other Important Tools")
2026-05-14 13:58:43,638 INFO ipython oit.link_count = 4 + len(pkg_links)
2026-05-14 13:58:43,638 INFO ipython # Now rebuild idx ordering: walk through links, group by card,
2026-05-14 13:58:43,638 INFO ipython # and append packaging links to Other Important Tools group.
2026-05-14 13:58:43,638 INFO ipython links_by_idx = sorted(ws.links, key=lambda x: x.idx)
2026-05-14 13:58:43,638 INFO ipython groups = []  # list of (card_break, [links])
2026-05-14 13:58:43,639 INFO ipython current = None
2026-05-14 13:58:43,639 INFO ipython for l in links_by_idx:
    if l.type == "Card Break":
        current = (l, [])
        groups.append(current)
    else:
        # Skip packaging links here; we re-insert them under OIT
        if l in pkg_links:
            continue
        if current:
            current[1].append(l)
2026-05-14 13:58:43,639 INFO ipython # Append packaging links under Other Important Tools
2026-05-14 13:58:43,639 INFO ipython for g in groups:
    if g[0].label == "Other Important Tools":
        g[1].extend(pkg_links)
        break
2026-05-14 13:58:43,640 INFO ipython # Reassign idx values sequentially
2026-05-14 13:58:43,640 INFO ipython new_idx = 1
2026-05-14 13:58:43,640 INFO ipython for cb, items in groups:
    cb.idx = new_idx; new_idx += 1
    for l in items:
        l.idx = new_idx; new_idx += 1
2026-05-14 13:58:43,641 INFO ipython # Update content JSON to remove the Packaging Module card
2026-05-14 13:58:43,641 INFO ipython content = json.loads(ws.content) if isinstance(ws.content, str) else (ws.content or [])
2026-05-14 13:58:43,642 INFO ipython content = [c for c in content if not (c.get("type") == "card" and c.get("data", {}).get("card_name") == "Packaging Module")]
2026-05-14 13:58:43,642 INFO ipython ws.content = json.dumps(content)
2026-05-14 13:58:43,642 INFO ipython ws.flags.ignore_links = True
2026-05-14 13:58:43,642 INFO ipython ws.flags.ignore_validate = True
2026-05-14 13:58:43,643 INFO ipython ws.flags.ignore_mandatory = True
2026-05-14 13:58:43,643 INFO ipython ws.save(ignore_permissions=True)
2026-05-14 13:58:43,643 INFO ipython frappe.db.commit()
2026-05-14 13:58:43,644 INFO ipython print("Saved. Total links:", len(ws.links))
2026-05-14 13:58:43,644 INFO ipython print("OIT link_count now:", oit.link_count)
2026-05-14 13:58:43,644 INFO ipython === session end ===
